# ============================================
# Brief AI — Переменные окружения
# ============================================
# Скопируйте в .env и заполните значения:
#   cp .env.example .env

# --------------------------------------------
# PostgreSQL
# --------------------------------------------
# Строка подключения. При использовании docker-compose.yml
# менять не нужно — значения по умолчанию совпадают.
DATABASE_URL=postgresql://brief_ai:brief_ai_pass@localhost:5432/brief_ai

# Максимум соединений в пуле (по умолчанию 20)
# DB_POOL_MAX=20

# --------------------------------------------
# Redis
# --------------------------------------------
# Используется для кэширования сессий (TTL 1 час)
# и rate limiting (60 запросов/минуту).
REDIS_URL=redis://localhost:6379

# --------------------------------------------
# Claude API (Anthropic)
# --------------------------------------------
# Получите ключ: https://console.anthropic.com/
# Обязательно для работы AI-диалога и генерации ТЗ.
ANTHROPIC_API_KEY=sk-ant-...

# Модель Claude (по умолчанию claude-sonnet-4-20250514)
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# --------------------------------------------
# Аутентификация (JWT)
# --------------------------------------------
# Секрет для подписи JWT-токенов.
# В production используйте криптографически стойкий ключ:
#   openssl rand -base64 32
NEXTAUTH_SECRET=your-secret-key-change-in-production

# URL приложения (для CORS и редиректов)
NEXTAUTH_URL=http://localhost:3000

# --------------------------------------------
# Приложение
# --------------------------------------------
NODE_ENV=development

# Порт dev-сервера (по умолчанию 3000)
# PORT=3000
